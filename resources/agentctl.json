{
  "$schema": "v1",
  "tools": [
    {
      "name": "engram",
      "desc": "Persistent memory for AI coding agents",
      "install": {
        "brew": "gentleman-programming/tap/engram"
      },
      "setup": ["engram setup {{target}}"],
      "targets": ["opencode", "claude-code"]
    },
    {
      "name": "codegraph",
      "desc": "Pre-indexed code knowledge graph",
      "install": {
        "npm": "@colbymchenry/codegraph"
      },
      "setup": ["codegraph install --target={{target}} --yes"]
    },
    {
      "name": "graphify",
      "desc": "Knowledge graph for codebases",
      "install": {
        "uv": "graphifyy"
      },
      "setup": ["graphify install --platform {{target}}"]
    },
    {
      "name": "superpowers",
      "desc": "AI development methodology skills",
      "plugin": {
        "opencode": "superpowers@git+https://github.com/obra/superpowers.git",
        "claude-code": "superpowers@claude-plugins-official"
      }
    }
  ],
  "resources": "*"
}
